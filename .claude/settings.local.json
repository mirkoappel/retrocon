{
  "permissions": {
    "allow": [
      "Bash(npm install *)",
      "Bash(node server.js)",
      "Bash(curl -s http://localhost:3000/api/info)",
      "Bash(curl -s -o /dev/null -w \"game.html: %{http_code}\\\\n\" http://localhost:3000/)",
      "Bash(curl -s -o /dev/null -w \"controller: %{http_code}\\\\n\" \"http://localhost:3000/controller.html?player=1\")",
      "Bash(curl -s -o /dev/null -w \"api:        %{http_code}\\\\n\" http://localhost:3000/api/info)",
      "Bash(/usr/libexec/ApplicationFirewall/socketfilterfw --getglobalstate)",
      "Bash(lsof -nP -iTCP:3000 -sTCP:LISTEN)",
      "Bash(curl -s -o /dev/null -w \"external IP reachable: %{http_code}\\\\n\" --max-time 3 http://192.168.2.160:3000/api/info)",
      "Bash(brew install *)",
      "Bash(gh auth *)",
      "Bash(gh api *)"
    ]
  }
}
